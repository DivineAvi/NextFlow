# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/nextflow?sslmode=require"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# Google Generative AI (Gemini) — get free key at https://aistudio.google.com
GEMINI_API_KEY="AIza..."

# Trigger.dev — get from https://cloud.trigger.dev
TRIGGER_SECRET_KEY="tr_dev_..."

# Transloadit (optional — media tasks return base64 URLs without this)
TRANSLOADIT_KEY=""
TRANSLOADIT_SECRET=""
